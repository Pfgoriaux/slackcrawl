# Required: Slack bot token (xoxb-...).
# The bot must be invited to every channel you want monitored.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# API keys for agent/user queries. Use named keys for a per-caller audit trail:
#   SLACKCRAWL_API_KEYS=data-team:LONG_RANDOM_SECRET,ci-bot:ANOTHER_LONG_SECRET
# Generate secrets with e.g. `openssl rand -hex 24`. Keys must be >= 16 chars.
SLACKCRAWL_API_KEYS=

# Or a single key (name defaults to "default"). Merged with the above if both are set.
# SLACKCRAWL_API_KEY=

# Set true ONLY to intentionally run unauthenticated (otherwise serve refuses to start
# with no key). Never do this on an internet-reachable deployment.
# SLACKCRAWL_ALLOW_NO_AUTH=false

# Optional: comma-separated channel names or IDs to monitor.
# If unset, the bot syncs ALL public + private channels it has been invited to.
# Removing a channel here stops syncing it but never deletes its history.
SLACKCRAWL_CHANNELS=

# Optional: incremental polling interval (default 10m). Go duration: 5m, 30m, 1h.
SLACKCRAWL_SYNC_INTERVAL=10m

# Optional: full reconciliation interval (default 24h). Catches edits, deletions, and
# any missed replies. Set 0 to disable.
# SLACKCRAWL_RECONCILE_INTERVAL=24h

# Optional: re-poll replies for threads active within N days each incremental cycle.
# SLACKCRAWL_THREAD_REPOLL_DAYS=14

# Optional: Slack pacing. Raise the min interval if your app is on Slack's new
# ~1 req/min tier (apps created after 2025-05-29). Page limit is clamped to 15 there.
# SLACKCRAWL_SLACK_MIN_INTERVAL_MS=1200
# SLACKCRAWL_SLACK_PAGE_LIMIT=200

# Optional: hard cap on any limit/last query param.
# SLACKCRAWL_MAX_LIMIT=500

# Optional: path to persist the SQLite database.
# Default: ~/.slackcrawl  — In Docker/Coolify set to: DATA_DIR=/data
# DATA_DIR=/data

# Optional: HTTP bind. Use 127.0.0.1 unless behind a trusted TLS proxy.
# SLACKCRAWL_HOST=0.0.0.0
# PORT=8080

# ---- AI Enrichment (optional) ----
# Both keys required to enable enrichment. No keys = zero behavior change.

# Claude API key for summaries, decision extraction, and digests.
# CLAUDE_API_KEY=sk-ant-...

# OpenAI API key for text embeddings (semantic search).
# OPENAI_API_KEY=sk-...

# Optional: override default models.
# CLAUDE_MODEL=claude-sonnet-4-6
# EMBEDDING_MODEL=text-embedding-3-small

# Optional: enrichment tuning.
# SLACKCRAWL_ENRICH_BATCH=100          # embedding batch size
# SLACKCRAWL_ENRICH_MIN_REPLIES=2      # min replies to trigger thread summary
# SLACKCRAWL_ENRICH_MAX_PER_CYCLE=500  # cap items per stage per cycle (bounds cost/time)
